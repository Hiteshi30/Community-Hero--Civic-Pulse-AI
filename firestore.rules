rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    // Departments: Anyone can read; Signed in municipal users can write
    match /departments/{deptId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Rewards: Anyone can read; Signed in administrators can write
    match /rewards/{rewardId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Complaints: Anyone can read; Authenticated citizens can create/support; Officers can update status
    match /complaints/{complaintId} {
      allow read, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn();
    }

    // Users Profiles: Publicly readable; owner or logged-in operator can write
    match /users/{userId} {
      allow read: if true;
      allow write, update: if isOwner(userId) || isSignedIn();
    }

    // Claimed Rewards: Logged-in citizens can transact rewards
    match /user_rewards/{rewardId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn();
    }

    // Notifications: Active tracking and alert dispatches
    match /notifications/{notifId} {
      allow read, write: if isSignedIn();
    }

    // Comments: Anyone can read; Authenticated users can write comments
    match /comments/{commentId} {
      allow read, list: if true;
      allow create, update, delete: if isSignedIn();
    }
  }
}
